<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#1e293b"/>
      <stop offset="50%" stop-color="#6b21a8"/>
      <stop offset="100%" stop-color="#1e293b"/>
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="96" fill="url(#bg)"/>
  <!-- Horloge -->
  <circle cx="256" cy="256" r="160" fill="none" stroke="#e9d5ff" stroke-width="20"/>
  <circle cx="256" cy="256" r="10" fill="#e9d5ff"/>
  <!-- Aiguilles -->
  <line x1="256" y1="256" x2="256" y2="140" stroke="#e9d5ff" stroke-width="16" stroke-linecap="round"/>
  <line x1="256" y1="256" x2="340" y2="256" stroke="#e9d5ff" stroke-width="12" stroke-linecap="round"/>
  <!-- Marqueurs 12-3-6-9 -->
  <circle cx="256" cy="116" r="8" fill="#e9d5ff"/>
  <circle cx="396" cy="256" r="8" fill="#e9d5ff"/>
  <circle cx="256" cy="396" r="8" fill="#e9d5ff"/>
  <circle cx="116" cy="256" r="8" fill="#e9d5ff"/>
</svg>
